# Auth
JARVIS_AUTH_TOKEN=<generate-a-random-string>
JARVIS_DAILY_API_LIMIT=50

# Supabase
NEXT_PUBLIC_SUPABASE_URL=<from-supabase-dashboard>
NEXT_PUBLIC_SUPABASE_ANON_KEY=<from-supabase-dashboard>
SUPABASE_SERVICE_ROLE_KEY=<from-supabase-dashboard>

# Claude API (use JARVIS_ANTHROPIC_KEY to avoid conflict with Claude Code env)
ANTHROPIC_API_KEY=<claude-api-key>
JARVIS_ANTHROPIC_KEY=<claude-api-key>

# Notion
NOTION_API_KEY=<notion-integration-token>
NOTION_TASKS_DB_ID=<notion-database-id>
NOTION_FITNESS_DB_ID=<notion-fitness-schedule-database-id>

# OpenAI (TTS)
OPENAI_API_KEY=<openai-api-key>

# Microsoft OAuth (Azure AD app registration)
MICROSOFT_CLIENT_ID=<azure-app-client-id>
MICROSOFT_CLIENT_SECRET=<azure-app-client-secret>
NEXT_PUBLIC_APP_URL=<your-app-url-for-oauth-callback>

# Google OAuth (Google Cloud Console)
GOOGLE_CLIENT_ID=<google-oauth-client-id>
GOOGLE_CLIENT_SECRET=<google-oauth-client-secret>

# Cron auth (for Railway scheduled tasks)
CRON_SECRET=<generate-a-random-string>

# Garmin Connect (unofficial API)
GARMIN_EMAIL=<garmin-connect-email>
GARMIN_PASSWORD=<garmin-connect-password>
